# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Postgres (host=db inside docker compose, localhost for local runs)
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# RAG provider: "openai" for live calls, "fake" for offline/deterministic dev
RAG_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Models / retrieval tuning
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
CHAT_MODEL=gpt-4o-mini
CHUNK_TOKENS=500
CHUNK_OVERLAP=50
TOP_K=5

# Throttling
THROTTLE_QUERY=30/minute
THROTTLE_INGEST=10/minute
