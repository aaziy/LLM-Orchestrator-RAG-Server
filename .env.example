# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Postgres (host=db inside docker compose, localhost for local runs)
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# RAG provider: "openai" for live calls, "fake" for offline/deterministic dev
RAG_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Models / retrieval tuning
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
CHAT_MODEL=gpt-4o-mini
CHUNK_TOKENS=500
CHUNK_OVERLAP=50
TOP_K=5

# Hybrid search (vector + Postgres full-text via reciprocal rank fusion)
HYBRID=1
CANDIDATE_POOL=20
RRF_K=60

# Reranking: "local" (cross-encoder, offline), "cohere", or "fake" (tests)
RERANK=1
RERANKER=local
RERANK_CANDIDATES=20
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# Async ingestion (Celery + Redis)
ASYNC_INGEST=1
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL / CELERY_RESULT_BACKEND default to REDIS_URL

# Throttling
THROTTLE_QUERY=30/minute
THROTTLE_INGEST=10/minute

# Tracing / observability: "auto" (langfuse if keys set, else off), "none",
# "langfuse", or "memory". Run Langfuse with: docker compose --profile observability up
TRACING=auto
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_HOST=http://localhost:3000
# Used only by the langfuse container at first boot:
LANGFUSE_NEXTAUTH_SECRET=please-change-me
LANGFUSE_SALT=please-change-me
LANGFUSE_INIT_USER_PASSWORD=langfuse123
